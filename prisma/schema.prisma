generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String
  role      Role
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  pelanggan Pelanggan?
  petugas   Petugas?

  @@index([username])
}

model Pelanggan {
  id        String      @id @default(uuid())
  nik       String      @unique
  nama      String
  alamat    String
  telp      String
  userId    String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id])
  pembelian Pembelian[]

  @@index([userId])
}

model Petugas {
  id        String   @id @default(uuid())
  nama      String
  alamat    String
  telp      String
  userId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Kereta {
  id        String    @id @default(uuid())
  nama      String
  deskripsi String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  gerbong   Gerbong[]
  jadwal    Jadwal[]

  @@index([nama])
}

model Gerbong {
  id        String            @id @default(uuid())
  nama      String
  kuota     Int
  kelas     Kelas
  keretaId  String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  detail    DetailPembelian[]
  kereta    Kereta            @relation(fields: [keretaId], references: [id])
  kursi     Kursi[]

  @@index([keretaId])
}

model Kursi {
  id        String            @id @default(uuid())
  row       Int
  seat      String
  label     String
  gerbongId String
  detail    DetailPembelian[]
  gerbong   Gerbong           @relation(fields: [gerbongId], references: [id])

  @@unique([gerbongId, row, seat])
  @@unique([gerbongId, label])
  @@index([gerbongId])
}

model Jadwal {
  id               String            @id @default(uuid())
  asal             String
  tujuan           String
  tanggalBerangkat DateTime
  tanggalTiba      DateTime
  harga            Decimal           @db.Decimal(10, 2)
  keretaId         String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  detail           DetailPembelian[]
  kereta           Kereta            @relation(fields: [keretaId], references: [id])
  pembelian        Pembelian[]

  @@index([keretaId])
  @@index([asal])
  @@index([tujuan])
  @@index([tanggalBerangkat])
}

model Pembelian {
  id          String            @id @default(uuid())
  kodeBooking String            @unique
  tanggal     DateTime          @default(now())
  status      StatusPembelian   @default(PENDING)
  pelangganId String
  jadwalId    String
  total       Decimal           @db.Decimal(10, 2)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  detail      DetailPembelian[]
  payment     Payment?
  jadwal      Jadwal            @relation(fields: [jadwalId], references: [id])
  pelanggan   Pelanggan         @relation(fields: [pelangganId], references: [id])

  @@index([pelangganId])
  @@index([jadwalId])
  @@index([status])
}

model DetailPembelian {
  id            String    @id @default(uuid())
  namaPenumpang String
  pembelianId   String
  kursiId       String
  gerbongId     String
  jadwalId      String
  gerbong       Gerbong   @relation(fields: [gerbongId], references: [id])
  jadwal        Jadwal    @relation(fields: [jadwalId], references: [id])
  kursi         Kursi     @relation(fields: [kursiId], references: [id])
  pembelian     Pembelian @relation(fields: [pembelianId], references: [id])

  @@unique([kursiId, jadwalId])
  @@index([pembelianId])
  @@index([jadwalId])
  @@index([gerbongId])
}

model Payment {
  id          String    @id @default(uuid())
  metode      String    @default("QRIS")
  qrImageUrl  String?
  paidAt      DateTime?
  refundedAt  DateTime?
  pembelianId String    @unique
  createdAt   DateTime  @default(now())
  pembelian   Pembelian @relation(fields: [pembelianId], references: [id])

  @@index([pembelianId])
}

enum Role {
  ADMIN
  PELANGGAN
}

enum Kelas {
  EKSEKUTIF
  EKONOMI
}

enum StatusPembelian {
  PENDING
  PAID
  CANCELED
}
